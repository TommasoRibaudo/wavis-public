# Allow insecure TLS connections (skip certificate verification).
# Set to "true" ONLY for local development against self-signed certs.
# MUST be "false" in production builds — users should never connect over http.
VITE_ALLOW_INSECURE_TLS=false

# General frontend diagnostic logging for prefixed [wavis:*] console output.
# Keep this off unless you are actively debugging client behavior.
VITE_DEBUG_LOGS=false

# General Rust/Tauri diagnostic logging.
# Enables info-level Rust logs and gated stderr diagnostics.
WAVIS_DEBUG_LOGS=false

# Screen capture diagnostic logging.
# Set to "true" to enable verbose frame-level logging for debugging
# screen share issues (listener timing, frame counts, publish ordering).
# Both flags default to off — no performance impact in production.
VITE_DEBUG_SCREEN_CAPTURE=false
WAVIS_DEBUG_SCREEN_CAPTURE=false

# Screen share viewer connection diagnostics.
# Set to "true" to log WebRTC loopback bridge ICE/SDP transitions, track events,
# and retry scheduling in the viewer (WatchAllPage, StreamReceiver, resendStream).
VITE_DEBUG_SCREEN_SHARE_VIEW=false

# Debug overlay for screen share viewer
# Set to "true" to show debug overlay with stream state information
VITE_DEBUG_SHOW_STREAM_OVERLAY=false

# Audio output routing diagnostics.
# Set to "true" to log every step of AudioContext.setSinkId routing:
# saved device ID, setSinkId support, success/failure, devicechange events.
# Use this to diagnose screen share audio loopback issues.
VITE_DEBUG_AUDIO_OUTPUT=false

# Diagnostics window build inclusion.
# Set to "true" to include the diagnostics window in the build and enable auto-open.
# When false (or absent), DiagnosticsPage is excluded from the bundle entirely.
# Also requires WAVIS_DIAGNOSTICS_WINDOW=1 at runtime to auto-open.
VITE_DIAGNOSTICS=false
