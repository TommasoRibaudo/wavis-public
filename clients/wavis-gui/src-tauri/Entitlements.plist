<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required for Chromium/WebKit JIT compilation -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- Required for microphone access (voice chat) -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- Required for AudioHardwareCreateProcessTap (system audio capture with process exclusion) -->
	<!-- This grants TCC permission for the "System Audio Recording" capability -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
